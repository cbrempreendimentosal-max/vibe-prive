# PostgreSQL local (desenvolvimento com Docker)
# docker run -d -e POSTGRES_USER=vibe -e POSTGRES_PASSWORD=vibe -e POSTGRES_DB=vibe_dev -p 5432:5432 postgres:15
DATABASE_URL="postgresql://vibe:vibe@localhost:5432/vibe_dev"

# Railway injeta DATABASE_URL automaticamente ao adicionar o plugin PostgreSQL

# Autenticação do painel /admin — defina valores fortes em produção (Railway > Variables)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
# String aleatória usada para assinar o cookie de sessão. Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me"
